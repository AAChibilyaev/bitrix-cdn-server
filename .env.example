# CDN Server Environment Configuration
# Copy to .env and fill with your values

# Bitrix Server Connection
BITRIX_SERVER_IP=192.168.1.10
BITRIX_SERVER_USER=www-data
BITRIX_UPLOAD_PATH=/var/www/bitrix/upload

# CDN Configuration
CDN_DOMAIN=cdn.example.com
CDN_SERVER_IP=192.168.1.20

# WebP Conversion Settings
WEBP_QUALITY=85
WEBP_MAX_WIDTH=2048
WEBP_MAX_HEIGHT=2048

# Cache Settings
CACHE_CLEANUP_DAYS=30
CACHE_MAX_SIZE=10G

# Monitoring
ADMIN_EMAIL=admin@example.com
GRAFANA_USER=admin
GRAFANA_PASSWORD=secure_password_here

# Performance Tuning
NGINX_WORKERS=auto
NGINX_CONNECTIONS=1024
VARNISH_MEMORY=1G

# Redis Settings
REDIS_MAXMEMORY=512mb
REDIS_PASSWORD=

# SSL Settings
LETSENCRYPT_EMAIL=admin@example.com
SSL_CERT_PATH=/etc/letsencrypt/live/cdn.example.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/cdn.example.com/privkey.pem

# Debug Mode
DEBUG=0
